{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        { "type": "host", "value": "nameerbag.com" }
      ],
      "destination": "https://www.nameerbag.com/:path*",
      "statusCode": 301
    }
  ],
  "headers": [
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "private, no-cache, no-store, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/ru/:path*",
      "headers": [
        { "key": "Cache-Control", "value": "private, no-cache, no-store, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/products/:path*",
      "headers": [
        { "key": "Cache-Control", "value": "private, no-cache, no-store, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/blog/:path*",
      "headers": [
        { "key": "Cache-Control", "value": "private, no-cache, no-store, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/:page(custom-service|factory|about|contact|privacy-policy)",
      "headers": [
        { "key": "Cache-Control", "value": "private, no-cache, no-store, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
